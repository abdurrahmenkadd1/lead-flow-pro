# LeadFlow Pro — Environment Variables Example
# Copy this file to `.env` and fill in your values.

# The URL of your N8N Webhook (production starts with /webhook/, testing starts with /webhook-test/)
VITE_N8N_WEBHOOK_URL=https://kaddourn8n.online/webhook/leadflow-search

# Use mock data instead of calling live N8N API (true/false)
VITE_USE_MOCK_DATA=false
